{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "subforge",
  "main": "src/worker.ts",
  "compatibility_date": "2025-01-15",
  "compatibility_flags": ["nodejs_compat"],
  // 前端静态资源（构建后的 SPA）；/api/* 与 /sub/* 交给 Worker 处理
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/sub/*", "/healthz"]
  },
  // D1 数据库绑定；database_id 由 `wrangler d1 create subforge` 生成后填入
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "subforge",
      "database_id": "REPLACE_WITH_YOUR_D1_ID",
      "migrations_dir": "migrations"
    }
  ],
  "observability": { "enabled": true }
  // Agent（可选）：wrangler secret put OPENAI_BASE_URL / OPENAI_API_KEY / OPENAI_MODEL
  // 管理口令（可选）：wrangler secret put ADMIN_TOKEN
}
