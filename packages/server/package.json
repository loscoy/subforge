{
  "name": "@subforge/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "mcp": "tsx src/mcp/stdio.ts",
    "cf:wasm": "node scripts/copy-quickjs-wasm.mjs",
    "precf:dev": "npm run cf:wasm",
    "cf:dev": "wrangler dev",
    "precf:deploy": "npm run cf:wasm",
    "cf:deploy": "wrangler deploy",
    "cf:release": "node scripts/cf-release.mjs",
    "cf:migrate:local": "wrangler d1 migrations apply subforge --local",
    "cf:migrate:remote": "wrangler d1 migrations apply subforge --remote",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^0.1.0",
    "@hono/node-server": "^1.13.7",
    "@jitl/quickjs-singlefile-browser-release-sync": "^0.31.0",
    "@jitl/quickjs-wasmfile-release-sync": "^0.31.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@subforge/core": "0.1.0",
    "ai": "^4.0.30",
    "better-sqlite3": "^11.7.0",
    "hono": "^4.6.14",
    "quickjs-emscripten": "^0.31.0",
    "quickjs-emscripten-core": "^0.31.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/better-sqlite3": "^7.6.12",
    "wrangler": "^4.112.0"
  }
}
